# AI Entegrasyonu — Görev 2 & 3
# Bu dosyayı .env olarak kopyalayıp değerleri doldur:
#   cp .env.example .env
#
# NOT: API anahtarı burada DEĞİL, root .env'de tutulur (AI_API_KEY) —
# istekler backend'in /ai/chat proxy'si üzerinden gider.

# Provider: "openai" veya "anthropic" (root .env'deki AI_API_PROVIDER ile aynı olmalı)
VITE_AI_API_PROVIDER=openai

# Kullanılacak model
# OpenAI önerileni   : gpt-4o-mini (ucuz, vision destekli, yeterince akıllı)
# OpenAI güçlü       : gpt-4o
# Anthropic önerileni: claude-haiku-4-5-20251001
VITE_AI_MODEL=gpt-4o-mini
