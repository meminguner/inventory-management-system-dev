PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=ims
JWT_KEY=change-me-to-a-long-random-secret

# --- Docker Compose ---
# Web container'inin host port'u (varsayilan 3000)
WEB_PORT=3000

# AI entegrasyonu
# Anahtar SADECE backend'de tutulur (/ai/chat proxy) — bundle'a girmez
AI_API_PROVIDER=openai
AI_API_KEY=

# Bunlar build sirasinda frontend bundle'ina gomulur (gizli degil)
# VITE_AI_API_PROVIDER, AI_API_PROVIDER ile ayni olmali
VITE_AI_API_PROVIDER=openai
VITE_AI_MODEL=gpt-4o-mini
